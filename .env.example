# ─── Database ──────────────────────────────────────────────────────────────────
SN_DATABASE_URL=postgresql+psycopg://surginote:surginote@localhost:5432/surginote

# ─── Redis (ARQ job queue) ──────────────────────────────────────────────────────
SN_REDIS_URL=redis://localhost:6379/0

# ─── Object storage (MinIO / AWS S3) ──────────────────────────────────────────
SN_S3_ENDPOINT_URL=http://localhost:9000
SN_S3_ACCESS_KEY=minioadmin
SN_S3_SECRET_KEY=minioadmin
SN_S3_BUCKET=surginote-uploads
SN_S3_REGION=us-east-1
SN_S3_USE_SSL=false

# ─── Secret provider: env | mapped (prod: wire Vault/AWS SM behind mapped aliases) ──
SN_SECRET_PROVIDER=env

# ─── Gemini — never commit real keys ──────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Report settings ───────────────────────────────────────────────────────────
SN_REPORT_LOCALE=en
SN_CONTRADICTION_SCORE_RATIO_THRESHOLD=0.8
SN_FLAG_POLICY=phase_window_then_case_wide

# ─── Security ──────────────────────────────────────────────────────────────────
# Webhook signing — use a strong random secret in production
SN_WEBHOOK_SIGNING_KEY=change-me-to-a-strong-random-value-in-prod
# CORS — comma-separated allowed origins; use "*" only for local dev
SN_CORS_ORIGINS=*
# Rate limiting — per-IP, format: "N/period" (minute|hour|day)
SN_RATE_LIMIT=120/minute
# Debug mode — set to true ONLY locally; exposes internal error details
SN_DEBUG=false

# ─── Local dev overrides (bypasses MinIO/ARQ worker) ─────────────────────────
SN_SKIP_OBJECT_STORAGE=true
SN_SYNC_JOBS=true
